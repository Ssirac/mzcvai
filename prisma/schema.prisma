generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(RECRUITER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  RECRUITER
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SponsorshipSignal {
  YES
  LIKELY
  UNKNOWN
  NO
}

enum ApplyChannel {
  EMAIL
  FORM
  PHONE
  UNKNOWN
}

enum VacancyStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum MatchStatus {
  SUGGESTED
  APPROVED
  SENT
  REPLIED
  INTERVIEW
  PLACED
  REJECTED
}

enum OutreachStatus {
  DRAFT
  APPROVED
  SENT
  OPENED
  REPLIED
  BOUNCED
}

enum OutreachChannel {
  EMAIL
  PHONE
}

enum CandidateStatus {
  ACTIVE   // aktiv / aktiv
  PENDING  // gözləmədə / wartet
  PLACED   // işə düzəldi / vermittelt
  ARCHIVED // arxivləndi / archiviert
}

// ─── Core Models ──────────────────────────────────────────────────────────────

// GDPR note: only generic company contacts stored here, never personal HR data
model Employer {
  id                 String            @id @default(cuid())
  name               String
  website            String?
  city               String?
  region             String?
  stars              Int?
  rooms              Int?
  sourceRef          String?
  // Contact — GDPR: generic only (info@, bewerbung@), NOT personal HR email
  genericEmail       String?
  emailSource        String?           // where genericEmail came from: listing|hunter|apollo|google|website
  emailStatus        String?           // verification result: deliverable|risky|undeliverable|unknown
  bouncedEmails      String[]          @default([]) // addresses that hard-bounced — never reuse
  optedOut           Boolean           @default(false) // employer asked to stop (UWG opt-out)
  applyFormUrl       String?
  phone              String?
  sponsorshipSignal  SponsorshipSignal @default(UNKNOWN)
  score              Int               @default(0)
  scoreBreakdown     Json?
  scoreUpdatedAt     DateTime?
  lastEnrichedAt     DateTime?
  enrichmentError    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  vacancies   Vacancy[]
  signalLogs  EmployerSignalLog[]
  matches     Match[]

  @@unique([website, name])
  @@index([score])
  @@index([region, sponsorshipSignal])
}

model Vacancy {
  id             String        @id @default(cuid())
  employerId     String
  employer       Employer      @relation(fields: [employerId], references: [id])
  title          String
  beruf          String
  region         String
  employmentType String?
  source         String        @default("arbeitsagentur") // arbeitsagentur | arbeitnow | manual
  url            String?
  description    String?       @db.Text
  sourceRef      String        @unique
  applyChannel   ApplyChannel  @default(UNKNOWN)
  applyValue     String?
  postedAt       DateTime?
  foundAt        DateTime      @default(now())
  status         VacancyStatus @default(ACTIVE)
  rawData        Json?
  matches        Match[]

  @@index([beruf, region, status])
  @@index([foundAt])
}

model Candidate {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  phone            String?
  beruf            String
  regionPrefs      String[]
  languages        String[]
  needsSponsorship Boolean   @default(true)
  visaStatus       String?
  notes            String?
  status           CandidateStatus @default(ACTIVE)
  // ── Detailed CV data ──
  dateOfBirth       DateTime?
  gender            String?
  nationality       String?
  maritalStatus     String?
  currentCity       String?
  currentCountry    String?
  address           String?
  photoUrl          String?
  desiredPosition   String?
  yearsExperience   Int?
  salaryExpectation String?
  availableFrom     DateTime?
  willingToRelocate Boolean   @default(true)
  drivingLicense    String?
  germanLevel       String?
  education         Json?     // [{ school, degree, field, from, to }]
  experience        Json?     // [{ company, title, from, to, description }]
  skills            String[]  @default([])
  certificates      String[]  @default([])
  // Original uploaded CV file (attached to outreach as-is)
  cvData            Bytes?
  cvFileName        String?
  cvMimeType        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  matches          Match[]
}

model Match {
  id           String      @id @default(cuid())
  candidateId  String
  candidate    Candidate   @relation(fields: [candidateId], references: [id])
  vacancyId    String
  vacancy      Vacancy     @relation(fields: [vacancyId], references: [id])
  employerId   String
  employer     Employer    @relation(fields: [employerId], references: [id])
  fitScore     Int
  fitBreakdown Json?
  status       MatchStatus @default(SUGGESTED)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  outreach     Outreach[]

  @@unique([candidateId, vacancyId])
  @@index([status])
}

// GDPR: toAddress must be generic company contact only — enforced at service layer
model Outreach {
  id         String          @id @default(cuid())
  matchId    String
  match      Match           @relation(fields: [matchId], references: [id])
  draftBody  String          @db.Text
  subject    String?
  channel    OutreachChannel @default(EMAIL)
  toAddress  String?
  status     OutreachStatus  @default(DRAFT)
  approvedBy String?
  approvedAt DateTime?
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  bouncedAt  DateTime?
  // Delivery/engagement tracking (Resend webhooks)
  providerId   String?   // Resend message id, to match webhook events
  deliveredAt  DateTime?
  openCount    Int       @default(0)
  // Reply capture (IMAP poll of the IONOS inbox)
  replyText    String?   @db.Text
  replyFrom    String?   // sender of the reply ("Name <email>")
  replySubject String?   // reply subject line
  // Follow-up sequence
  followUpCount  Int       @default(0)
  lastFollowUpAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([status, sentAt])
  @@index([providerId])
}

model EmployerSignalLog {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])
  eventType  String
  eventData  Json?
  occurredAt DateTime @default(now())
  source     String

  @@index([employerId, eventType])
}

model IngestionRun {
  id               String   @id @default(cuid())
  beruf            String
  region           String
  source           String   @default("arbeitsagentur")
  status           String
  vacanciesNew     Int      @default(0)
  vacanciesUpdated Int      @default(0)
  employersNew     Int      @default(0)
  errorMessage     String?
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
}
