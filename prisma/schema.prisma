generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(RECRUITER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  RECRUITER
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SponsorshipSignal {
  YES
  LIKELY
  UNKNOWN
  NO
}

enum ApplyChannel {
  EMAIL
  FORM
  PHONE
  UNKNOWN
}

enum VacancyStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum MatchStatus {
  SUGGESTED
  APPROVED
  SENT
  REPLIED
  INTERVIEW
  PLACED
  REJECTED
}

enum OutreachStatus {
  DRAFT
  APPROVED
  SENT
  OPENED
  REPLIED
  BOUNCED
}

enum OutreachChannel {
  EMAIL
  PHONE
}

enum CandidateStatus {
  ACTIVE   // aktiv / aktiv
  PENDING  // gözləmədə / wartet
  PLACED   // işə düzəldi / vermittelt
  ARCHIVED // arxivləndi / archiviert
}

// Recruiter placement pipeline — a candidate's stage from intake to placement.
// Additive alongside CandidateStatus (which stays for backward compat).
enum PipelineStage {
  NEW
  PROFILE_READY
  MATCHED
  PRESENTED
  INTERVIEW
  VISA
  PLACED
  REJECTED
  ARCHIVED
}

// Employer relationship stage (CRM).
enum CrmStatus {
  LEAD
  CONTACTED
  ACTIVE
  PARTNER
  DORMANT
  BLOCKED
}

// Visa-readiness / document checklist item types + states.
enum DocType {
  PASSPORT
  DIPLOMA
  CERTIFICATE
  LANGUAGE_CERT
  CV
  PHOTO
  VISA
  OTHER
}
enum DocStatus {
  MISSING
  UPLOADED
  VERIFIED
}

// Why a match was marked bad — feeds future scoring tuning.
enum FeedbackReason {
  SKILL_MISMATCH
  SALARY
  LOCATION
  VISA
  LANGUAGE
  OVERQUALIFIED
  OTHER
}

// ─── Core Models ──────────────────────────────────────────────────────────────

// GDPR note: only generic company contacts stored here, never personal HR data
model Employer {
  id                 String            @id @default(cuid())
  name               String
  website            String?
  city               String?
  region             String?
  stars              Int?
  rooms              Int?
  sourceRef          String?
  // Contact — GDPR: generic only (info@, bewerbung@), NOT personal HR email
  genericEmail       String?
  emailSource        String?           // where genericEmail came from: listing|hunter|apollo|google|website
  emailStatus        String?           // verification result: deliverable|risky|undeliverable|unknown
  bouncedEmails      String[]          @default([]) // addresses that hard-bounced — never reuse
  optedOut           Boolean           @default(false) // employer asked to stop (UWG opt-out)
  applyFormUrl       String?
  phone              String?
  // Auto-outreach governance (Feature 3): never email an employer that hasn't
  // consented; cap how many candidate presentations they get per day.
  outreachConsent    Boolean           @default(false)
  dailyOutreachCap   Int               @default(5)
  sponsorshipSignal  SponsorshipSignal @default(UNKNOWN)
  score              Int               @default(0)
  scoreBreakdown     Json?
  scoreUpdatedAt     DateTime?
  lastEnrichedAt     DateTime?
  enrichmentError    String?
  // CRM (recruiter relationship management) — additive, all optional/default.
  crmStatus          CrmStatus         @default(LEAD)
  crmNotes           String?           @db.Text
  lastContactAt      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  vacancies   Vacancy[]
  signalLogs  EmployerSignalLog[]
  matches     Match[]
  followUps   EmployerFollowUp[]

  @@unique([website, name])
  @@index([score])
  @@index([region, sponsorshipSignal])
  @@index([crmStatus])
}

model Vacancy {
  id             String        @id @default(cuid())
  employerId     String
  employer       Employer      @relation(fields: [employerId], references: [id])
  title          String
  beruf          String
  region         String
  employmentType String?
  source         String        @default("arbeitsagentur") // arbeitsagentur | arbeitnow | manual
  url            String?
  description    String?       @db.Text
  sourceRef      String        @unique
  contentHash    String?       // sha256(title|employer|location) — cross-source duplicate detection
  applyChannel   ApplyChannel  @default(UNKNOWN)
  applyValue     String?
  postedAt       DateTime?
  foundAt        DateTime      @default(now())
  lastSeenAt     DateTime      @default(now()) // refreshed each time a source re-lists it; stale = filled/dead
  status         VacancyStatus @default(ACTIVE)
  rawData        Json?
  matches        Match[]

  @@index([beruf, region, status])
  @@index([foundAt])
  @@index([lastSeenAt])
  @@index([contentHash])
}

model Candidate {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  phone            String?
  beruf            String
  regionPrefs      String[]
  languages        String[]
  needsSponsorship Boolean   @default(true)
  visaStatus       String?
  notes            String?
  status           CandidateStatus @default(ACTIVE)
  // Recruiter placement pipeline stage (additive alongside `status`).
  pipelineStage    PipelineStage   @default(NEW)
  // ── Detailed CV data ──
  dateOfBirth       DateTime?
  gender            String?
  nationality       String?
  maritalStatus     String?
  currentCity       String?
  currentCountry    String?
  address           String?
  photoUrl          String?
  desiredPosition   String?
  yearsExperience   Int?
  salaryExpectation String?
  availableFrom     DateTime?
  willingToRelocate Boolean   @default(true)
  drivingLicense    String?
  germanLevel       String?
  education         Json?     // [{ school, degree, field, from, to }]
  experience        Json?     // [{ company, title, from, to, description }]
  skills            String[]  @default([])
  certificates      String[]  @default([])
  // Original uploaded CV file (attached to outreach as-is)
  cvData            Bytes?
  cvFileName        String?
  cvMimeType        String?
  // Auto-outreach gate (Feature 3): a half-finished profile is never presented
  // to an employer. Recomputed from the profile fields on save / matching.
  profileComplete   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  matches          Match[]
  pipelineEvents   PipelineEvent[]
  documents        CandidateDocument[]

  @@index([pipelineStage])
}

model Match {
  id           String      @id @default(cuid())
  candidateId  String
  candidate    Candidate   @relation(fields: [candidateId], references: [id])
  vacancyId    String
  vacancy      Vacancy     @relation(fields: [vacancyId], references: [id])
  employerId   String
  employer     Employer    @relation(fields: [employerId], references: [id])
  fitScore     Int
  fitBreakdown Json?
  status       MatchStatus @default(SUGGESTED)
  // Recruiter feedback (GOOD | BAD) — captured to tune future scoring.
  feedback       String?
  feedbackReason FeedbackReason? // structured "why bad" category (additive)
  feedbackNote   String?
  feedbackBy     String?
  feedbackAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  outreach     Outreach[]

  @@unique([candidateId, vacancyId])
  @@index([status])
  @@index([feedback])
}

// GDPR: toAddress must be generic company contact only — enforced at service layer
model Outreach {
  id         String          @id @default(cuid())
  matchId    String
  match      Match           @relation(fields: [matchId], references: [id])
  draftBody  String          @db.Text
  subject    String?
  channel    OutreachChannel @default(EMAIL)
  toAddress  String?
  status     OutreachStatus  @default(DRAFT)
  // Attribution: which campaign + which letter-template version produced this.
  campaign        String?
  templateVersion String?
  approvedBy String?
  approvedAt DateTime?
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  bouncedAt  DateTime?
  // Delivery/engagement tracking (Resend webhooks)
  providerId   String?   // Resend message id, to match webhook events
  deliveredAt  DateTime?
  openCount    Int       @default(0)
  // Reply capture (IMAP poll of the IONOS inbox)
  replyText    String?   @db.Text
  replyFrom    String?   // sender of the reply ("Name <email>")
  replySubject String?   // reply subject line
  replyRead    Boolean   @default(false) // has the user seen this reply (inbox badge)
  // Follow-up sequence
  followUpCount  Int       @default(0)
  lastFollowUpAt DateTime?
  // Manual replies the user sent back from the inbox (in-app, no IONOS webmail)
  outboundReplies OutboundReply[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([status, sentAt])
  @@index([providerId])
}

// A reply the user typed and sent from the in-app inbox (with optional file
// attachments), so they never have to open the IONOS webmail. Stored so the
// thread shows both the employer's message and our answer.
model OutboundReply {
  id          String   @id @default(cuid())
  outreachId  String
  outreach    Outreach @relation(fields: [outreachId], references: [id], onDelete: Cascade)
  toAddress   String
  subject     String
  body        String   @db.Text
  attachments Json?    // [{ filename, size }] — metadata only, not the bytes
  sentBy      String?  // session user who sent it
  provider    String?
  providerId  String?
  createdAt   DateTime @default(now())

  @@index([outreachId])
}

model EmployerSignalLog {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])
  eventType  String
  eventData  Json?
  occurredAt DateTime @default(now())
  source     String

  @@index([employerId, eventType])
}

model IngestionRun {
  id               String   @id @default(cuid())
  beruf            String
  region           String
  source           String   @default("arbeitsagentur")
  status           String
  vacanciesNew     Int      @default(0)
  vacanciesUpdated Int      @default(0)
  vacanciesDead    Int      @default(0) // dead/expired listings removed during this run
  employersNew     Int      @default(0)
  errorMessage     String?
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
}

// Human-in-the-loop queue for external job applications that hit a captcha /
// bot-wall the automation must NOT solve. Instead of failing silently, the apply
// flow enqueues the application here so an admin can open the direct link, clear
// the captcha by hand and finish it. See services/captcha.
model CaptchaQueue {
  id             String    @id @default(cuid())
  jobId          String
  candidateId    String
  platform       String    // HOGAPAGE, StepStone, Indeed, LinkedIn, …
  jobTitle       String
  company        String
  applicationUrl String    // DIRECT application link the admin opens
  matchScore     Float
  blockedReason  String    // "recaptcha_v2", "cloudflare", "hcaptcha", …
  prefilledData  Json      // snapshot of the fields to fill in
  status         String    @default("PENDING") // PENDING|IN_PROGRESS|SUBMITTED|SKIPPED|FAILED
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([jobId, candidateId])
  @@index([status, createdAt])
}

// Governed auto-outreach to employers (Feature 3). One row per attempt/decision,
// with a hard unique on (candidate, employer, job) so the same presentation is
// never emailed twice — idempotency + audit trail in one place.
model EmployerOutreachLog {
  id           String   @id @default(cuid())
  candidateId  String
  employerId   String
  jobId        String
  template     String
  status       String   // SENT | FAILED | SKIPPED_DEDUPE | SKIPPED_DAILY_LIMIT | DRY_RUN | HELD_FOR_REVIEW
  error        String?
  sentAt       DateTime @default(now())

  @@unique([candidateId, employerId, jobId])
  @@index([employerId, sentAt])
  @@index([status])
}

// Audit log of external form-based job applications (Feature: apply scanner).
// One row per (candidate, vacancy); status tracks the human-in-the-loop lifecycle.
model JobApplicationLog {
  id          String   @id @default(cuid())
  candidateId String
  vacancyId   String
  company     String
  position    String
  link        String
  source      String
  // APPLIED | ALREADY_APPLIED | WAITING_CAPTCHA | WAITING_OTP | FILLED | ERROR | INTERVIEW | OFFER
  status      String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([candidateId, vacancyId])
  @@index([status, createdAt])
  @@index([candidateId])
}

// Security audit trail: who did what, when. Written for sensitive actions
// (login, candidate CRUD, CV up/download, outreach approve/send, opt-out, GDPR
// export/delete). Append-only; never exposed to the client verbatim.
model AuditLog {
  id         String   @id @default(cuid())
  actor      String   // session username (or "system" for automated actions)
  action     String   // LOGIN | CANDIDATE_CREATE | CV_DOWNLOAD | OUTREACH_SEND | OPT_OUT | GDPR_EXPORT | GDPR_DELETE ...
  targetType String?  // candidate | outreach | employer | ...
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// Distributed lock for cron jobs — prevents a second run (another instance or an
// overlapping tick) from starting the same job. Expired locks are stealable.
model CronLock {
  name      String   @id
  owner     String
  lockedAt  DateTime @default(now())
  expiresAt DateTime
}

// Persisted cron-run history (status, duration, result) for the admin UI.
model CronRun {
  id         String    @id @default(cuid())
  job        String
  status     String    // running | completed | failed | skipped_locked
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  durationMs Int?
  result     Json?
  error      String?

  @@index([job, startedAt])
}

// ─── Recruiter CRM & Placement Pipeline (additive) ────────────────────────────

// Stage-transition history for a candidate's placement pipeline.
model PipelineEvent {
  id          String        @id @default(cuid())
  candidateId String
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fromStage   PipelineStage?
  toStage     PipelineStage
  actor       String?       // session user who moved it
  note        String?
  createdAt   DateTime      @default(now())

  @@index([candidateId, createdAt])
}

// A logged touchpoint with an employer (recruiter CRM follow-up trail).
model EmployerFollowUp {
  id            String    @id @default(cuid())
  employerId    String
  employer      Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  contactedAt   DateTime  @default(now())
  outcome       String?
  nextStep      String?
  nextStepDueAt DateTime?
  actor         String?
  createdAt     DateTime  @default(now())

  @@index([employerId, contactedAt])
  @@index([nextStepDueAt])
}

// Visa-readiness / document checklist item for a candidate.
model CandidateDocument {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type        DocType
  status      DocStatus @default(MISSING)
  note        String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([candidateId, type])
  @@index([candidateId])
}
