# ─── Database ─────────────────────────────────────────────────────────────────
# Standard PostgreSQL connection string (Supabase, Neon, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mzaicv?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET also signs the admin session cookie — use a long random string.
NEXTAUTH_SECRET="your-long-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Admin login that protects the whole panel (pages + API).
ADMIN_USER="admin"
ADMIN_PASSWORD="set-a-strong-password"

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── SMTP (Nodemailer) ────────────────────────────────────────────────────────
# Use the mail provider that hosts mz-personalvermittlung.de (e.g. IONOS, Strato, Google Workspace).
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="info@mz-personalvermittlung.de"
SMTP_PASS="yourpassword"
SMTP_FROM="MZ Personalvermittlung <info@mz-personalvermittlung.de>"
# Agency signature appended to every application letter
AGENCY_NAME="MZ Personalvermittlung"
AGENCY_PHONE=""
AGENCY_CONTACT_EMAIL="info@mz-personalvermittlung.de"
AGENCY_WEBSITE="https://mz-personalvermittlung.de"

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Max outreach emails per day (safety cap)
MAX_OUTREACH_PER_DAY="20"
# Min days between outreach to same employer
OUTREACH_COOLDOWN_DAYS="30"
# TEST MODE: while set, ALL outreach goes to this address instead of real
# employers (for verifying the flow). Leave empty in production.
OUTREACH_TEST_RECIPIENT=""

# ─── Adzuna job aggregator (optional 3rd source) ──────────────────────────────
# Aggregates all German job boards + company career pages. Free: https://developer.adzuna.com
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
# Jooble aggregator (optional). Free key: https://jooble.org/api/about
JOOBLE_API_KEY=""

# ─── Auto-apply engine (FORM-based applications) ──────────────────────────────
# Server-side headless-Puppeteer submission of FORM applications. OFF by default;
# even when enabled it is DRY-RUN (fills + reports, never clicks submit) until you
# explicitly set DRY_RUN=false. captcha/OTP/login forms and any form with a
# missing required field are ALWAYS routed to the human robot queue, never
# auto-submitted. See src/services/autoApply.ts.
AUTO_FORM_APPLY_ENABLED="false"        # master switch — "true" to run the engine
AUTO_FORM_APPLY_DRY_RUN="true"         # "false" to actually submit captcha-free forms
AUTO_FORM_APPLY_ACCEPT_CONSENT="false" # "true" to auto-tick required privacy/consent checkboxes
AUTO_FORM_APPLY_REQUIRE_CV="true"      # only apply for candidates with an uploaded CV
AUTO_FORM_APPLY_DAILY_CAP="20"         # max real submissions per day (all candidates)
AUTO_FORM_APPLY_LIMIT="15"             # max form matches scanned per run
AUTO_FORM_APPLY_INTERVAL_HOURS="6"     # scheduler cadence when enabled
# LLM assist: when a required field can't be mapped by the static matcher, ask
# Claude (structure only — NEVER candidate PII) to map it + reject non-application
# forms. Fires only when there are gaps, so no cost on clean forms. "false" to off.
AUTO_FORM_APPLY_LLM="true"
FORM_CLASSIFIER_MODEL="claude-haiku-4-5-20251001"
# Firecrawl (FIRECRAWL_API_KEY, below) is used automatically when set: if a page
# has no form, the engine finds the real "Jetzt bewerben" link and retries there.

# ─── External tooling / MCP (optional) ────────────────────────────────────────
# Project-scoped MCP servers are declared in .mcp.json and activate only when
# their key is present. A missing key just makes that server unavailable — it
# never breaks the app. See docs/tooling-setup.md for the full catalog.
# context7 (upstash) — up-to-date library docs. Works without a key; a key raises
# rate limits (get one via `npx ctx7 setup`).
CONTEXT7_API_KEY=""
# firecrawl — web scraping/crawling API. Required for the firecrawl MCP server.
FIRECRAWL_API_KEY=""

# Legal note: This is not legal advice.
# User must consult a German GDPR/UWG lawyer before scaling outreach operations.
